{
  "name": "recorda",
  "version": "0.1.4",
  "description": "Modern Windows screen recorder — Electron + React + FFmpeg",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .\"",
    "build:web": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:web && npm run build:electron",
    "start": "npm run build && cross-env ELECTRON_RUN_AS_NODE= electron .",
    "package": "npm run build && electron-builder --win --x64",
    "fetch-ffmpeg": "powershell -ExecutionPolicy Bypass -File scripts/fetch-ffmpeg.ps1",
    "build:icon": "node scripts/build-icon.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.5.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "dev.recorda.app",
    "productName": "recorda",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      },
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "win": {
      "icon": "resources/icons/recorda.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "recorda",
      "installerIcon": "resources/icons/recorda.ico",
      "uninstallerIcon": "resources/icons/recorda.ico",
      "installerHeaderIcon": "resources/icons/recorda.ico",
      "artifactName": "recorda-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "recorda-Portable-${version}.${ext}"
    }
  }
}
